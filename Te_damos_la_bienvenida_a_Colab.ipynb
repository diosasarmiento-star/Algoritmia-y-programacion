
        "import pandas as pd\n",
        "from datetime import datetime, timedelta\n",
        "import os\n",
        "\n",
        "# --- CONFIGURACIÓN INICIAL ---\n",
        "# Definición de archivos planos (CSV) para persistencia de datos [cite: 55]\n",
        "USUARIOS_FILE = 'usuarios.csv'\n",
        "ITEMS_FILE = 'inventario.csv'\n",
        "PRESTAMOS_FILE = 'prestamos.csv'\n",
        "\n",
        "def inicializar_archivos():\n",
        "    if not os.path.exists(USUARIOS_FILE):\n",
        "        pd.DataFrame(columns=['Nombre', 'Apellido', 'Documento', 'Correo', 'Dias_Permitidos']).to_csv(USUARIOS_FILE, index=False)\n",
        "    if not os.path.exists(ITEMS_FILE):\n",
        "        pd.DataFrame(columns=['ID', 'Nombre', 'Categoria', 'Precio', 'Estado']).to_csv(ITEMS_FILE, index=False)\n",
        "    if not os.path.exists(PRESTAMOS_FILE):\n",
        "        pd.DataFrame(columns=['ID_Item', 'Doc_Usuario', 'Fecha_Prestamo', 'Estado']).to_csv(PRESTAMOS_FILE, index=False)\n",
        "\n",
        "# --- VALIDACIONES ---\n",
        "def validar_nombre_apellido(texto):\n",
        "    # No menos de 3 letras y sin números [cite: 117, 119]\n",
        "    return len(texto) >= 3 and texto.isalpha()\n",
        "\n",
        "def validar_documento(doc):\n",
        "    # Entre 3 y 15 dígitos, solo números [cite: 125, 126]\n",
        "    return doc.isdigit() and 3 <= len(doc) <= 15\n",
        "\n",
        "# --- FUNCIONALIDADES PRINCIPALES ---\n",
        "\n",
        "def registrar_usuario():\n",
        "    print(\"\\n--- Registro de Usuario ---\")\n",
        "    nombre = input(\"Nombre: \")\n",
        "    apellido = input(\"Apellido: \")\n",
        "\n",
        "    if not (validar_nombre_apellido(nombre) and validar_nombre_apellido(apellido)):\n",
        "        print(\"Error: Nombre o Apellido inválidos (mínimo 3 letras, sin números).\")\n",
        "        return\n",
        "\n",
        "    doc = input(\"Documento (3-15 dígitos): \")\n",
        "    if not validar_documento(doc):\n",
        "        print(\"Error: Documento debe ser numérico y tener entre 3 y 15 dígitos.\")\n",
        "        return\n",
        "\n",
        "    correo = input(\"Correo electrónico: \")\n",
        "    if not (correo.endswith(\".com\") and \"@\" in correo): # [cite: 127]\n",
        "        print(\"Error: Formato de correo inválido.\")\n",
        "        return\n",
        "\n",
        "    dias = input(\"Días de préstamo (5, 10, 15, 30): \")\n",
        "    if dias not in ['5', '10', '15', '30']: # [cite: 128]\n",
        "        print(\"Error: Tiempo de préstamo no permitido.\")\n",
        "        return\n",
        "\n",
        "    # Guardar en CSV\n",
        "    nuevo_usuario = pd.DataFrame([[nombre, apellido, doc, correo, dias]],\n",
        "                                 columns=['Nombre', 'Apellido', 'Documento', 'Correo', 'Dias_Permitidos'])\n",
        "    nuevo_usuario.to_csv(USUARIOS_FILE, mode='a', header=False, index=False)\n",
        "    print(\"¡Usuario registrado con éxito!\")\n",
        "\n",
        "def registrar_item():\n",
        "    print(\"\\n--- Registrar Ítem ---\")\n",
        "    nombre = input(\"Nombre del artículo: \")\n",
        "    if len(nombre) < 3: # [cite: 132]\n",
        "        print(\"Error: El nombre debe tener al menos 3 caracteres.\")\n",
        "        return\n",
        "\n",
        "    print(\"Categorías: 1. Videojuegos, 2. Libros, 3. Música/Video, 4. Herramientas, 5. Dinero, 6. Misceláneo\")\n",
        "    cat_opcion = input(\"Seleccione categoría: \")\n",
        "    categorias = {\"1\": \"Videojuegos\", \"2\": \"Libros\", \"3\": \"Musica\", \"4\": \"Herramientas\", \"5\": \"Dinero\", \"6\": \"Miscelaneo\"}\n",
        "    categoria = categorias.get(cat_opcion, \"Miscelaneo\") # [cite: 146-154]\n",
        "\n",
        "    precio = float(input(\"Precio de compra: \")) # [cite: 155]\n",
        "    item_id = f\"{categoria[:3].upper()}-{datetime.now().strftime('%S%f')}\" # [cite: 156]\n",
        "\n",
        "    # Lógica difusa simple para estado (Ej: Excelente, Bueno, Regular) [cite: 158]\n",
        "    estado = input(\"Estado del ítem (Excelente/Bueno/Regular): \")\n",
        "\n",
        "    nuevo_item = pd.DataFrame([[item_id, nombre, categoria, precio, estado]],\n",
        "                              columns=['ID', 'Nombre', 'Categoria', 'Precio', 'Estado'])\n",
        "    nuevo_item.to_csv(ITEMS_FILE, mode='a', header=False, index=False)\n",
        "    print(f\"Ítem registrado con ID: {item_id}\")\n",
        "\n",
        "def registrar_prestamo():\n",
        "    # Solo permite préstamos a usuarios registrados [cite: 160]\n",
        "    doc = input(\"Documento del usuario: \")\n",
        "    usuarios = pd.read_csv(USUARIOS_FILE)\n",
        "\n",
        "    if doc not in usuarios['Documento'].astype(str).values:\n",
        "        print(\"Usuario no encontrado. Debe registrarlo primero.\")\n",
        "        return\n",
        "\n",
        "    print(\"\\nArtículos disponibles:\")\n",
        "    items = pd.read_csv(ITEMS_FILE)\n",
        "    print(items)\n",
        "\n",
        "    id_item = input(\"Ingrese el ID del ítem a prestar: \")\n",
        "    if id_item not in items['ID'].values:\n",
        "        print(\"ID de ítem no válido.\")\n",
        "        return\n",
        "\n",
        "    fecha_hoy = datetime.now().strftime('%Y-%m-%d')\n",
        "    nuevo_p = pd.DataFrame([[id_item, doc, fecha_hoy, 'Activo']],\n",
        "                           columns=['ID_Item', 'Doc_Usuario', 'Fecha_Prestamo', 'Estado'])\n",
        "    nuevo_p.to_csv(PRESTAMOS_FILE, mode='a', header=False, index=False)\n",
        "    print(\"Préstamo registrado.\")\n",
        "\n",
        "def consultar_ventas_30_dias():\n",
        "    # Los ítems con más de 30 días se venden con impuesto del 23% [cite: 169]\n",
        "    print(\"\\n--- Ítems para Venta (Más de 30 días) ---\")\n",
        "    prestamos = pd.read_csv(PRESTAMOS_FILE)\n",
        "    items = pd.read_csv(ITEMS_FILE)\n",
        "    hoy = datetime.now()\n",
        "\n",
        "    for index, row in prestamos.iterrows():\n",
        "        fecha_p = datetime.strptime(row['Fecha_Prestamo'], '%Y-%m-%d')\n",
        "        if (hoy - fecha_p).days > 30 and row['Estado'] == 'Activo':\n",
        "            item_info = items[items['ID'] == row['ID_Item']].iloc[0]\n",
        "            precio_base = item_info['Precio']\n",
        "            total = precio_base * 1.23 # Impuesto por conchudez [cite: 169]\n",
        "            print(f\"VENTA OBLIGATORIA: {item_info['Nombre']} al usuario {row['Doc_Usuario']}\")\n",
        "            print(f\"Total a pagar (con 23% impuesto): ${total:.2f}\")\n",
        "\n",
        "# --- MENÚ PRINCIPAL ---\n",
        "def menu():\n",
        "    inicializar_archivos()\n",
        "    while True:\n",
        "        print(\"\\n============================\")\n",
        "        print(\"    PRESTAMIGOS    \") # NOMBRE\n",
        "        print(\"============================\")\n",
        "        print(\"1. Registrar Usuario\")\n",
        "        print(\"2. Registrar Ítem\")\n",
        "        print(\"3. Registrar Préstamo\")\n",
        "        print(\"4. Registrar Devolución\")\n",
        "        print(\"5. Consultar Ítems +30 días\")\n",
        "        print(\"6. Administrador\")\n",
        "        print(\"7. Salir\")\n",
        "\n",
        "        opcion = input(\"Seleccione una opción: \")\n",
        "\n",
        "        if opcion == \"1\": registrar_usuario()\n",
        "        elif opcion == \"2\": registrar_item()\n",
        "        elif opcion == \"3\": registrar_prestamo()\n",
        "        elif opcion == \"5\": consultar_ventas_30_dias()\n",
        "        elif opcion == \"7\": break\n",
        "        else: print(\"Opción en desarrollo o no válida.\")\n",
        "\n",
        "menu()\n"
      ],
